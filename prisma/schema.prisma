generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Single admin user ───
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Webmail accounts (warming + engagement) ───
enum WebmailProvider {
  GMAIL
  OUTLOOK
  YAHOO
  AOL
  CPANEL
}

enum WarmingStatus {
  NOT_STARTED
  WARMING
  READY
  PAUSED
  ISSUES
}

enum ScheduleType {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

model WebmailAccount {
  id       String          @id @default(cuid())
  email    String
  provider WebmailProvider

  // IMAP credentials (encrypted)
  imapHost     String?
  imapPort     Int?
  imapPassword String? @db.Text

  // SMTP settings
  smtpHost String?
  smtpPort Int?

  // Role: warming accounts send emails, engagement-only accounts just interact
  isWarmingAccount Boolean @default(false)

  // Warming state (only used when isWarmingAccount = true)
  warmingStatus   WarmingStatus @default(NOT_STARTED)
  warmingSchedule ScheduleType  @default(MODERATE)
  currentDay      Int           @default(0)
  dailyTarget     Int           @default(0)
  sentToday       Int           @default(0)
  reputationScore Float         @default(0)
  warmingStartedAt DateTime?
  pausedAt         DateTime?

  // AI context for content generation
  businessSummary  String?  @db.Text
  businessKeywords String[] @default([])

  // Initial domain analysis (JSON)
  initialAnalysis String? @db.Text

  // Health state
  isActive          Boolean   @default(true)
  lastCheckedAt     DateTime?
  lastError         String?
  consecutiveErrors Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  emailLogs             EmailLog[]
  seedAddresses         SeedAddress[]
  dailyStats            DailyStat[]
  warmingScheduleConfig WarmingScheduleConfig[]
  generatedContent      GeneratedContent[]
  engagementLogs        EngagementLog[]

  @@unique([email, provider])
  @@index([warmingStatus])
  @@index([isWarmingAccount, warmingStatus])
}

// ─── Per-day volume targets ───
model WarmingScheduleConfig {
  id        String         @id @default(cuid())
  accountId String
  account   WebmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  day       Int
  targetVolume Int

  @@unique([accountId, day])
}

// ─── Seed addresses for warming ───
model SeedAddress {
  id        String          @id @default(cuid())
  email     String
  accountId String?
  account   WebmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  isInternal Boolean        @default(false)
  createdAt  DateTime       @default(now())

  @@unique([email, accountId])
}

// ─── Email send log ───
model EmailLog {
  id            String         @id @default(cuid())
  accountId     String
  account       WebmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  smtpMessageId String?        @unique
  fromAddress   String
  toAddress     String
  subject       String
  bodyPreview   String?        @db.Text
  isReply       Boolean        @default(false)
  inReplyToId   String?
  shouldReply   Boolean        @default(false)
  replyScheduledAt DateTime?

  // Delivery status
  status        EmailStatus @default(QUEUED)
  deliveredAt   DateTime?
  openedAt      DateTime?
  bouncedAt     DateTime?
  complainedAt  DateTime?
  failedAt      DateTime?
  failureReason String?

  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  // Webmail engagement
  engagementLogs EngagementLog[]

  @@index([accountId, sentAt])
  @@index([smtpMessageId])
  @@index([status])
  @@index([shouldReply, replyScheduledAt])
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  BOUNCED
  COMPLAINED
  FAILED
}

// ─── Aggregated daily stats ───
model DailyStat {
  id        String         @id @default(cuid())
  accountId String
  account   WebmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date      DateTime       @db.Date
  sent      Int            @default(0)
  delivered Int            @default(0)
  opened    Int            @default(0)
  bounced   Int            @default(0)
  complained Int           @default(0)
  failed    Int            @default(0)

  @@unique([accountId, date])
  @@index([date])
}

// ─── Pre-generated email content pool ───
model GeneratedContent {
  id         String         @id @default(cuid())
  accountId  String
  account    WebmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  senderName String         @default("Team")
  subject    String
  body       String         @db.Text
  tone       String
  topic      String
  usedAt     DateTime?
  createdAt  DateTime       @default(now())

  @@index([accountId, usedAt])
}

// ─── App settings (singleton) ───
model Settings {
  id                       String  @id @default("singleton")
  openRouterApiKey         String? @db.Text
  defaultFromName          String  @default("Team")
  maxDailyGlobalEmails     Int     @default(500)
  warmingEnabled           Boolean @default(true)
  webmailEngagementEnabled Boolean @default(true)
}

// ─── Engagement tracking ───
enum EngagementAction {
  OPENED
  MOVED_TO_INBOX
  MARKED_NOT_SPAM
  REPLIED
  STARRED
}

model EngagementLog {
  id        String          @id @default(cuid())
  accountId String
  account   WebmailAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  emailLogId String?
  emailLog   EmailLog? @relation(fields: [emailLogId], references: [id], onDelete: SetNull)

  action      EngagementAction
  messageId   String?
  fromAddress String
  subject     String
  folder      String?

  performedAt DateTime @default(now())

  @@index([accountId, performedAt])
  @@index([emailLogId])
}
