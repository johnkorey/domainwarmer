# Database
DATABASE_URL="postgresql://user:password@localhost:5432/domain_warmer"

# Auth
JWT_SECRET="your-jwt-secret-min-32-chars-long-here"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# Encryption key for storing API keys at rest
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Mailgun
MAILGUN_API_KEY="your-mailgun-api-key"
MAILGUN_WEBHOOK_SIGNING_KEY="your-mailgun-webhook-signing-key"

# OpenRouter
OPENROUTER_API_KEY="your-openrouter-api-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="your-cron-secret-key"
